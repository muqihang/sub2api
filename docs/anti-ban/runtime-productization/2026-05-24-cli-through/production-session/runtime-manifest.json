        "allowed_account_ids": [
          "opaque:account-ref:v1:placeholder"
        ],
        "enabled": true,
        "proxy_url": "${CC_EGRESS_PROXY_URL}"
      }
    },
    "env": {
      "arch": "arm64",
      "deployment_environment": "production-session",
      "is_ci": false,
      "is_claude_ai_auth": true,
      "is_running_with_bun": false,
      "node_version": "v22.22.2",
