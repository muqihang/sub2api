          "decision": "gray_path"
        },
        "registry_profile": "claude_code_2_1_150_subscription_1m",
        "source_of_truth": "cc_gateway_dynamic_persona_resolver",
        "trusted_minor_drift": {
          "capability_downgrade_allowed": false,
          "decision": "observed_minor_drift",
          "example_version": "2.1.151"
        },
        "unknown_major": {
          "action": "fail_closed",
          "decision": "quarantine_version"
        },
        "version_family": "2.1"
      },
      "production_budget": {
        "enforcement_enabled": false,
        "mode": "observe_only",
        "p0_hard_block_only": true
