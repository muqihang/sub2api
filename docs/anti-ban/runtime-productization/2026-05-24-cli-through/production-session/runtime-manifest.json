      "shell": "zsh",
      "working_dir": "/Users/redacted/projects"
    },
    "providers": {
      "anthropic": true
    },
    "server": {
      "port": 18443,
      "tls": {
        "cert": "",
        "key": ""
      }
    },
    "shared_pool": {
      "billing_cch_mode": "sign",
      "candidate_model_allowlist": [
        "claude-sonnet-4-8",
        "claude-opus-4-8"
      ],
      "candidate_model_audit_budgets": {
        "claude-opus-4-8": 25,
        "claude-sonnet-4-8": 25
      },
      "candidate_model_kill_switches": {
        "claude-opus-4-8": false,
        "claude-sonnet-4-8": false
      },
      "candidate_model_replay_proofs": {
