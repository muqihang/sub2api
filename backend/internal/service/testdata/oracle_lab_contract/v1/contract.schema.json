{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oracle-lab.invalid/contracts/oracle.compatibility.v1/contract.schema.json",
  "title": "Oracle Compatibility Contract v1",
  "oneOf": [
    { "$ref": "#/$defs/signedManifest" },
    { "$ref": "#/$defs/behaviorCoherenceCertificate" },
    { "$ref": "#/$defs/readinessHandshake" },
    { "$ref": "#/$defs/lifecycleOperation" },
    { "$ref": "#/$defs/taskLineage" },
    { "$ref": "#/$defs/outcomeEnvelope" },
    { "$ref": "#/$defs/replayState" }
  ],
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "safeRef": { "type": "string", "minLength": 1, "maxLength": 200, "pattern": "^[A-Za-z0-9._:/-]+$" },
    "generation": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
    "timestamp": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
    "version": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_id", "schema_major", "schema_revision"],
      "properties": {
        "schema_id": { "const": "oracle.compatibility" },
        "schema_major": { "const": 1 },
        "schema_revision": { "const": 0 }
      }
    },
    "authorityState": {
      "enum": [
        "unverified",
        "package_observed",
        "local_wire_observed",
        "cross_checked",
        "gateway_wire_equivalent",
        "stateful_behavior_equivalent",
        "upstream_canary_observed",
        "production_verified"
      ]
    },
    "authoritySignal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signal_id", "authority_state", "observation_scope", "server_dependency",
        "stability_class", "confidence", "issued_at_ms", "expires_at_ms", "owner",
        "revalidation_command_id", "invalidating_dependency_digests", "negative_evidence",
        "contradictory_evidence", "contradiction_status", "minimum_authority_after_expiry",
        "affected_capabilities", "failure_action"
      ],
      "properties": {
        "signal_id": { "$ref": "#/$defs/safeRef" },
        "authority_state": { "$ref": "#/$defs/authorityState" },
        "observation_scope": { "enum": ["package", "local_fixture", "local_wire", "gateway", "staging", "canary", "production"] },
        "server_dependency": { "type": "boolean" },
        "stability_class": { "enum": ["immutable_package", "version_bound", "environment_bound", "server_dependent"] },
        "confidence": { "enum": ["unknown", "low", "medium", "high"] },
        "issued_at_ms": { "$ref": "#/$defs/timestamp" },
        "expires_at_ms": { "$ref": "#/$defs/timestamp" },
        "owner": { "$ref": "#/$defs/safeRef" },
        "revalidation_command_id": { "$ref": "#/$defs/safeRef" },
        "invalidating_dependency_digests": { "type": "array", "maxItems": 64, "uniqueItems": true, "items": { "$ref": "#/$defs/sha256" } },
        "negative_evidence": { "type": "array", "maxItems": 64, "uniqueItems": true, "items": { "$ref": "#/$defs/safeRef" } },
        "contradictory_evidence": { "type": "array", "maxItems": 64, "uniqueItems": true, "items": { "$ref": "#/$defs/safeRef" } },
        "contradiction_status": { "enum": ["none", "open", "resolved"] },
        "minimum_authority_after_expiry": { "$ref": "#/$defs/authorityState" },
        "affected_capabilities": { "type": "array", "minItems": 1, "maxItems": 128, "uniqueItems": true, "items": { "$ref": "#/$defs/safeRef" } },
        "failure_action": { "enum": ["disable", "rollback"] }
      }
    },
    "compatibilityGate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "evidence_ref", "authority_signal_id"],
      "properties": {
        "status": { "enum": ["pass", "fail", "unsupported", "unobserved"] },
        "evidence_ref": { "$ref": "#/$defs/safeRef" },
        "authority_signal_id": { "$ref": "#/$defs/safeRef" }
      }
    },
    "fourGates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["wire", "semantic", "state_sequence", "failure_semantics"],
      "properties": {
        "wire": { "$ref": "#/$defs/compatibilityGate" },
        "semantic": { "$ref": "#/$defs/compatibilityGate" },
        "state_sequence": { "$ref": "#/$defs/compatibilityGate" },
        "failure_semantics": { "$ref": "#/$defs/compatibilityGate" }
      }
    },
    "negativeCapabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["models", "beta_tokens", "transports", "entrypoints", "fallbacks", "feature_combinations", "authority_states"],
      "properties": {
        "models": { "type": "array", "maxItems": 256, "uniqueItems": true, "items": { "$ref": "#/$defs/safeRef" } },
        "beta_tokens": { "type": "array", "maxItems": 256, "uniqueItems": true, "items": { "$ref": "#/$defs/safeRef" } },
        "transports": { "type": "array", "maxItems": 64, "uniqueItems": true, "items": { "$ref": "#/$defs/safeRef" } },
        "entrypoints": { "type": "array", "maxItems": 64, "uniqueItems": true, "items": { "$ref": "#/$defs/safeRef" } },
        "fallbacks": { "type": "array", "maxItems": 64, "uniqueItems": true, "items": { "$ref": "#/$defs/safeRef" } },
        "feature_combinations": { "type": "array", "maxItems": 256, "uniqueItems": true, "items": { "$ref": "#/$defs/safeRef" } },
        "authority_states": { "type": "array", "maxItems": 8, "uniqueItems": true, "items": { "$ref": "#/$defs/authorityState" } }
      }
    },
    "behaviorCoherenceCertificate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_id", "schema_major", "schema_revision", "kind", "certificate_id",
        "package_name", "package_version", "package_artifact_sha256", "build_identity_ref",
        "platform", "architecture", "entrypoint", "auth_mode", "environment_profile_ref",
        "persona_ref", "request_ast_profile_ref", "response_profile_ref", "cch_policy_ref",
        "tls_http_profile_ref", "proxy_generation", "credential_generation", "retry_policy_ref",
        "state_sequence_ref", "failure_semantics_ref", "model_capability_set_ref",
        "contract_digest", "manifest_digest", "profile_generation", "sidecar_protocol_generation",
        "replay_ledger_generation", "gates", "dependency_digests"
      ],
      "properties": {
        "schema_id": { "const": "oracle.compatibility" },
        "schema_major": { "const": 1 },
        "schema_revision": { "const": 0 },
        "kind": { "const": "behavior_coherence_certificate" },
        "certificate_id": { "$ref": "#/$defs/safeRef" },
        "package_name": { "const": "@anthropic-ai/claude-code" },
        "package_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "package_artifact_sha256": { "$ref": "#/$defs/sha256" },
        "build_identity_ref": { "$ref": "#/$defs/safeRef" },
        "platform": { "$ref": "#/$defs/safeRef" },
        "architecture": { "$ref": "#/$defs/safeRef" },
        "entrypoint": { "$ref": "#/$defs/safeRef" },
        "auth_mode": { "$ref": "#/$defs/safeRef" },
        "environment_profile_ref": { "$ref": "#/$defs/safeRef" },
        "persona_ref": { "$ref": "#/$defs/safeRef" },
        "request_ast_profile_ref": { "$ref": "#/$defs/safeRef" },
        "response_profile_ref": { "$ref": "#/$defs/safeRef" },
        "cch_policy_ref": { "$ref": "#/$defs/safeRef" },
        "tls_http_profile_ref": { "$ref": "#/$defs/safeRef" },
        "proxy_generation": { "$ref": "#/$defs/generation" },
        "credential_generation": { "$ref": "#/$defs/generation" },
        "retry_policy_ref": { "$ref": "#/$defs/safeRef" },
        "state_sequence_ref": { "$ref": "#/$defs/safeRef" },
        "failure_semantics_ref": { "$ref": "#/$defs/safeRef" },
        "model_capability_set_ref": { "$ref": "#/$defs/safeRef" },
        "contract_digest": { "$ref": "#/$defs/sha256" },
        "manifest_digest": { "$ref": "#/$defs/sha256" },
        "profile_generation": { "$ref": "#/$defs/generation" },
        "sidecar_protocol_generation": { "$ref": "#/$defs/generation" },
        "replay_ledger_generation": { "$ref": "#/$defs/generation" },
        "gates": { "$ref": "#/$defs/fourGates" },
        "dependency_digests": { "type": "array", "minItems": 1, "maxItems": 128, "uniqueItems": true, "items": { "$ref": "#/$defs/sha256" } }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "key_id", "key_epoch", "role", "signature_base64url"],
      "properties": {
        "algorithm": { "const": "Ed25519" },
        "key_id": { "$ref": "#/$defs/safeRef" },
        "key_epoch": { "$ref": "#/$defs/generation" },
        "role": { "enum": ["root", "manifest", "checkpoint", "revocation", "sidecar_capability"] },
        "signature_base64url": { "type": "string", "pattern": "^[A-Za-z0-9_-]{86}$" }
      }
    },
    "signedManifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_id", "schema_major", "schema_revision", "kind", "signed", "signatures"],
      "properties": {
        "schema_id": { "const": "oracle.compatibility" },
        "schema_major": { "const": 1 },
        "schema_revision": { "const": 0 },
        "kind": { "const": "signed_manifest" },
        "signed": {
          "type": "object",
          "additionalProperties": false,
          "required": ["manifest_id", "policy_version", "parent_digest", "rollback_digest", "contract_digest", "issued_at_ms", "expires_at_ms", "source_package_digests", "promotion_refs", "witness_checkpoint_digest", "signals", "certificate", "negative_capabilities"],
          "properties": {
            "manifest_id": { "$ref": "#/$defs/safeRef" },
            "policy_version": { "$ref": "#/$defs/generation" },
            "parent_digest": { "$ref": "#/$defs/sha256" },
            "rollback_digest": { "$ref": "#/$defs/sha256" },
            "contract_digest": { "$ref": "#/$defs/sha256" },
            "issued_at_ms": { "$ref": "#/$defs/timestamp" },
            "expires_at_ms": { "$ref": "#/$defs/timestamp" },
            "source_package_digests": { "type": "array", "minItems": 1, "maxItems": 16, "uniqueItems": true, "items": { "$ref": "#/$defs/sha256" } },
            "promotion_refs": { "type": "array", "maxItems": 32, "uniqueItems": true, "items": { "$ref": "#/$defs/safeRef" } },
            "witness_checkpoint_digest": { "$ref": "#/$defs/sha256" },
            "signals": { "type": "array", "minItems": 1, "maxItems": 128, "items": { "$ref": "#/$defs/authoritySignal" } },
            "certificate": { "$ref": "#/$defs/behaviorCoherenceCertificate" },
            "negative_capabilities": { "$ref": "#/$defs/negativeCapabilities" }
          }
        },
        "signatures": { "type": "array", "minItems": 1, "maxItems": 64, "items": { "$ref": "#/$defs/signature" } }
      }
    },
    "supportedRange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_major", "minimum_revision", "maximum_revision"],
      "properties": {
        "schema_major": { "type": "integer", "minimum": 0 },
        "minimum_revision": { "type": "integer", "minimum": 0 },
        "maximum_revision": { "type": "integer", "minimum": 0 }
      }
    },
    "readinessHandshake": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_id", "schema_major", "schema_revision", "kind", "liveness", "readiness", "protected_capability", "build_digest", "contract_digest", "manifest_digest", "profile_generation", "sidecar_generation", "replay_ledger_generation", "supported_contracts", "disabled_capabilities", "expires_at_ms"],
      "properties": {
        "schema_id": { "const": "oracle.compatibility" },
        "schema_major": { "const": 1 },
        "schema_revision": { "const": 0 },
        "kind": { "const": "readiness_handshake" },
        "liveness": { "type": "boolean" },
        "readiness": { "type": "boolean" },
        "protected_capability": { "type": "boolean" },
        "build_digest": { "$ref": "#/$defs/sha256" },
        "contract_digest": { "$ref": "#/$defs/sha256" },
        "manifest_digest": { "$ref": "#/$defs/sha256" },
        "profile_generation": { "$ref": "#/$defs/generation" },
        "sidecar_generation": { "$ref": "#/$defs/generation" },
        "replay_ledger_generation": { "$ref": "#/$defs/generation" },
        "supported_contracts": { "type": "array", "minItems": 1, "maxItems": 16, "items": { "$ref": "#/$defs/supportedRange" } },
        "disabled_capabilities": { "type": "array", "maxItems": 128, "uniqueItems": true, "items": { "$ref": "#/$defs/safeRef" } },
        "expires_at_ms": { "$ref": "#/$defs/timestamp" }
      }
    },
    "lifecycleOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_id", "schema_major", "schema_revision", "kind", "operation", "owner", "account_ref", "account_generation", "credential_generation", "proxy_generation", "profile_generation", "expected_state_version", "next_state_version", "idempotency_key"],
      "properties": {
        "schema_id": { "const": "oracle.compatibility" },
        "schema_major": { "const": 1 },
        "schema_revision": { "const": 0 },
        "kind": { "const": "lifecycle_operation" },
        "operation": { "enum": ["register", "replace", "freeze", "drain", "revoke", "delete", "query", "reconcile"] },
        "owner": { "enum": ["sub2api", "cc_gateway"] },
        "account_ref": { "$ref": "#/$defs/safeRef" },
        "account_generation": { "$ref": "#/$defs/generation" },
        "credential_generation": { "$ref": "#/$defs/generation" },
        "proxy_generation": { "$ref": "#/$defs/generation" },
        "profile_generation": { "$ref": "#/$defs/generation" },
        "expected_state_version": { "$ref": "#/$defs/generation" },
        "next_state_version": { "$ref": "#/$defs/generation" },
        "idempotency_key": { "$ref": "#/$defs/safeRef" }
      }
    },
    "taskLineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_id", "schema_major", "schema_revision", "kind", "root_task_ref", "parent_task_ref", "current_task_ref", "client_generation", "profile_generation", "migration_sequence", "attempt_id", "deadline_ms", "idempotency_key"],
      "properties": {
        "schema_id": { "const": "oracle.compatibility" },
        "schema_major": { "const": 1 },
        "schema_revision": { "const": 0 },
        "kind": { "const": "task_lineage" },
        "root_task_ref": { "$ref": "#/$defs/safeRef" },
        "parent_task_ref": { "$ref": "#/$defs/safeRef" },
        "current_task_ref": { "$ref": "#/$defs/safeRef" },
        "client_generation": { "$ref": "#/$defs/generation" },
        "profile_generation": { "$ref": "#/$defs/generation" },
        "migration_sequence": { "$ref": "#/$defs/generation" },
        "attempt_id": { "$ref": "#/$defs/safeRef" },
        "deadline_ms": { "$ref": "#/$defs/timestamp" },
        "idempotency_key": { "$ref": "#/$defs/safeRef" }
      }
    },
    "outcomeEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_id", "schema_major", "schema_revision", "kind", "attempt_id", "transport_fact", "semantic_outcome", "partial_output", "tool_side_effect", "retry_owner", "terminal", "final_headers_sha256", "final_body_sha256"],
      "properties": {
        "schema_id": { "const": "oracle.compatibility" },
        "schema_major": { "const": 1 },
        "schema_revision": { "const": 0 },
        "kind": { "const": "outcome_envelope" },
        "attempt_id": { "$ref": "#/$defs/safeRef" },
        "transport_fact": { "enum": ["not_attempted", "connected", "reset", "timeout", "rejected"] },
        "semantic_outcome": { "enum": ["none", "success", "client_error", "rate_limited", "capacity", "server_error", "malformed", "cancelled"] },
        "partial_output": { "type": "boolean" },
        "tool_side_effect": { "type": "boolean" },
        "retry_owner": { "enum": ["none", "cc_gateway", "sub2api"] },
        "terminal": { "type": "boolean" },
        "final_headers_sha256": { "$ref": "#/$defs/sha256" },
        "final_body_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "replayState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_id", "schema_major", "schema_revision", "kind", "ledger_generation", "key_epoch", "capability_id", "attempt_id", "nonce", "state", "expires_at_ms"],
      "properties": {
        "schema_id": { "const": "oracle.compatibility" },
        "schema_major": { "const": 1 },
        "schema_revision": { "const": 0 },
        "kind": { "const": "replay_state" },
        "ledger_generation": { "$ref": "#/$defs/generation" },
        "key_epoch": { "$ref": "#/$defs/generation" },
        "capability_id": { "$ref": "#/$defs/safeRef" },
        "attempt_id": { "$ref": "#/$defs/safeRef" },
        "nonce": { "$ref": "#/$defs/safeRef" },
        "state": { "enum": ["reserved", "committed", "expired", "revoked"] },
        "expires_at_ms": { "$ref": "#/$defs/timestamp" }
      }
    }
  }
}
